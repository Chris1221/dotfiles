[commit]
	gpgsign = true
[alias]
	apply-gitignore = !git ls-files -ci --exclude-standard -z | xargs -0r git rm --cached

[url "git@github.com:"]
	insteadOf = "gh:"

[include]
	path = ~/.gitconfig.local


[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
